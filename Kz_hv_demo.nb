Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"kzNE", "[", 
      RowBox[{"Ehv_", ",", "V0_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"0.5123", "^", "2"}], " ", "V0"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"0.5123", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Ehv", "-", "W"}], "]"}], " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"th", " ", "Degree"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Ehv", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{
               RowBox[{"Pi", "/", "4"}], "+", 
               RowBox[{"th", " ", "Degree"}]}], "]"}]}], ")"}], "/", 
           "1973"}]}], ")"}], "^", "2"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"ymesh", "=", 
     RowBox[{"Range", "[", 
      RowBox[{
       RowBox[{"Floor", "[", 
        RowBox[{
         RowBox[{"kzNE", "[", 
          RowBox[{"hvmin", ",", "V0"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"Pi", "/", "c"}]}], ")"}]}], "]"}], ",", 
       RowBox[{"Ceiling", "[", 
        RowBox[{
         RowBox[{"kzNE", "[", 
          RowBox[{
           RowBox[{"hvmin", "+", "dhv"}], ",", "V0"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"Pi", "/", "c"}]}], ")"}]}], "]"}], ",", "1"}], "]"}]}], 
    ";", "\[IndentingNewLine]", 
    RowBox[{"xmesh", "=", 
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Ehv", "/.", " ", 
          RowBox[{"FindRoot", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"kzNE", "[", 
               RowBox[{"Ehv", ",", "V0"}], "]"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", 
                RowBox[{"Pi", "/", "c"}]}], ")"}]}], "==", "#"}], ",", 
            RowBox[{"{", 
             RowBox[{"Ehv", ",", 
              RowBox[{"hvmin", "/", "2"}]}], "}"}]}], "]"}]}], "&"}], "/@", 
        "ymesh"}], ",", "0.01"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"kzNE", "[", 
         RowBox[{"Ehv", ",", "V0"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"Pi", "/", "c"}]}], ")"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Ehv", ",", "hvmin", ",", 
        RowBox[{"hvmin", "+", "dhv"}]}], "}"}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xmesh", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"xmesh", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"ymesh", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"ymesh", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], "}"}]}], "}"}]}], ",", 
      RowBox[{"GridLines", "->", 
       RowBox[{"{", 
        RowBox[{"xmesh", ",", "ymesh"}], "}"}]}], ",", 
      RowBox[{"Ticks", "->", 
       RowBox[{"{", 
        RowBox[{"xmesh", ",", "ymesh"}], "}"}]}], ",", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<E_photon [eV]\>\"", ",", "\"\<kz [pi/c]\>\""}], "}"}]}], 
      ",", 
      RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}], "\[IndentingNewLine]", 
   ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"hvmin", ",", "80", ",", "\"\<Min. photon energy (eV)\>\""}], 
     "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"dhv", ",", "100", ",", "\"\<Photon energy range (eV)\>\""}], 
     "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{
     "c", ",", "9.4", ",", "\"\<Out-of-plane lattice constant (A)\>\""}], 
     "}"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"W", ",", "4.45", ",", "\"\<Work function (eV)\>\""}], "}"}], 
    "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"th", ",", "0", ",", "\"\<Cryostat rotation (Deg.)\>\""}], "}"}],
     "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"{", 
     RowBox[{"V0", ",", "12", ",", "\"\<Inner potential (eV)\>\""}], "}"}], 
    "}"}]}], "]"}]], "Input",
 CellChangeTimes->{3.9433165332257366`*^9, 3.943317954819833*^9, 
  3.9433195149704576`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"1c8a51fe-61b3-446f-b3f3-b27c622b6763"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`c$$ = 9.4, $CellContext`dhv$$ = 
    100, $CellContext`hvmin$$ = 80, $CellContext`th$$ = 0, $CellContext`V0$$ =
     12, $CellContext`W$$ = 4.45, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`hvmin$$], 80, "Min. photon energy (eV)"}}, {{
       Hold[$CellContext`dhv$$], 100, "Photon energy range (eV)"}}, {{
       Hold[$CellContext`c$$], 9.4, "Out-of-plane lattice constant (A)"}}, {{
       Hold[$CellContext`W$$], 4.45, "Work function (eV)"}}, {{
       Hold[$CellContext`th$$], 0, "Cryostat rotation (Deg.)"}}, {{
       Hold[$CellContext`V0$$], 12, "Inner potential (eV)"}}}, 
    Typeset`size$$ = {576., {166., 169.36797410065583`}}, Typeset`update$$ = 
    0, Typeset`initDone$$, Typeset`skipInitDone$$ = True}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`c$$ = 9.4, $CellContext`dhv$$ = 
        100, $CellContext`hvmin$$ = 80, $CellContext`th$$ = 
        0, $CellContext`V0$$ = 12, $CellContext`W$$ = 4.45}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> ($CellContext`kzNE[
          Pattern[$CellContext`Ehv$, 
           Blank[]], 
          Pattern[$CellContext`V0$, 
           Blank[]]] := 
        Sqrt[0.5123^2 $CellContext`V0$ + (
            0.5123 Sqrt[$CellContext`Ehv$ - $CellContext`W$$] 
             Cos[$CellContext`th$$ Degree] + ($CellContext`Ehv$ 
              Cos[Pi/4 + $CellContext`th$$ Degree])/
             1973)^2]; $CellContext`ymesh = Range[
          
          Floor[$CellContext`kzNE[$CellContext`hvmin$$, $CellContext`V0$$]/(
           2 (Pi/$CellContext`c$$))], 
          
          Ceiling[$CellContext`kzNE[$CellContext`hvmin$$ + \
$CellContext`dhv$$, $CellContext`V0$$]/(2 (Pi/$CellContext`c$$))], 
          1]; $CellContext`xmesh = Round[
          Map[ReplaceAll[$CellContext`Ehv, 
            
            FindRoot[$CellContext`kzNE[$CellContext`Ehv, $CellContext`V0$$]/(
              2 (Pi/$CellContext`c$$)) == #, {$CellContext`Ehv, \
$CellContext`hvmin$$/2}]]& , $CellContext`ymesh], 0.01]; 
       Plot[{$CellContext`kzNE[$CellContext`Ehv, $CellContext`V0$$]/(
          2 (Pi/$CellContext`c$$))}, {$CellContext`Ehv, $CellContext`hvmin$$, \
$CellContext`hvmin$$ + $CellContext`dhv$$}, PlotRange -> {{
            Part[$CellContext`xmesh, 1], 
            Part[$CellContext`xmesh, -1]}, {
            Part[$CellContext`ymesh, 1], 
            Part[$CellContext`ymesh, -1]}}, 
         GridLines -> {$CellContext`xmesh, $CellContext`ymesh}, 
         Ticks -> {$CellContext`xmesh, $CellContext`ymesh}, 
         AxesLabel -> {"E_photon [eV]", "kz [pi/c]"}, ImageSize -> Large]), 
      "Specifications" :> {{{$CellContext`hvmin$$, 80, 
          "Min. photon energy (eV)"}}, {{$CellContext`dhv$$, 100, 
          "Photon energy range (eV)"}}, {{$CellContext`c$$, 9.4, 
          "Out-of-plane lattice constant (A)"}}, {{$CellContext`W$$, 4.45, 
          "Work function (eV)"}}, {{$CellContext`th$$, 0, 
          "Cryostat rotation (Deg.)"}}, {{$CellContext`V0$$, 12, 
          "Inner potential (eV)"}}}, "Options" :> {}, 
      "DefaultOptions" :> {ControllerLinking -> True}],
     ImageSizeCache->{625., {258.8544921875, 264.1455078125}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    SynchronousInitialization->True,
    UndoTrackedVariables:>{Typeset`show$$, Typeset`bookmarkMode$$},
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
 CellChangeTimes->{
  3.9433174188004503`*^9, 3.9433179683987703`*^9, 3.9433180443522635`*^9, 
   3.943319530920082*^9, 3.943326788140414*^9, {3.9433268819070215`*^9, 
