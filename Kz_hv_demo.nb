Cell["\<\
This demonstration computes the exact photon energy at which the \
photo-electron have crystal momentum either at Brillouin zone center (Gamma) \
or at zone boundary. This is a useful tool for ARPES experiments. The photon \
momentum has been taken into account and therefore also valid for hard X-ray \
ARPES.\
\>", "ManipulateCaption",
 CellChangeTimes->{{3.943316578185915*^9, 3.9433165873487873`*^9}, {
  3.9433166743629985`*^9, 3.9433166823835564`*^9}, {3.943317072107636*^9, 
  3.9433171373861437`*^9}, {3.9433173548714333`*^9, 3.9433173550651445`*^9}, {
  3.943319222498743*^9, 3.9433193136527557`*^9}, {3.9433196403450975`*^9, 
  3.943319647907301*^9}, {3.943319705532805*^9, 
  3.943319751278466*^9}},ExpressionUUID->"71921e4e-c8c2-4f05-96e3-\
4e3047349e9a"]
}, Open  ]],

